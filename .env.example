# Токен Telegram-бота из @BotFather
BOT_TOKEN=your_telegram_bot_token

# Базовый шанс ответа, если к боту не обращались напрямую (0..1)
REPLY_PROBABILITY=0.08

# Минимальная пауза между самостоятельными ответами в одном чате (сек)
MIN_COOLDOWN_SEC=45

# Минимальный объём модели, после которого разрешается генерация
MIN_TOKENS_FOR_MODEL=200

# Максимальная длина сгенерированного сообщения
MAX_REPLY_CHARS=280

# Telegram user id владельца с расширенными правами (команды также доступны админам чата)
OWNER_ID=

# Приводить все токены к нижнему регистру перед обучением/генерацией (true/false)
NORMALIZE_LOWER=false

# Путь к SQLite-базе
DB_PATH=data/markov.db

# Диапазон задержки перед ответом для эффекта «печатает...»
TYPING_MIN_MS=350
TYPING_MAX_MS=1100

# Сила случайности генерации (0..3): чем больше, тем разнообразнее ответы
RANDOMNESS_STRENGTH=2.0

# Основной порядок цепи Маркова: 2 или 3
MARKOV_ORDER=3

# Разрешить fallback на более низкий порядок, если нет перехода высокого порядка
ENABLE_BACKOFF=true

# Минимальный порядок fallback: 1 или 2 (должен быть < MARKOV_ORDER)
BACKOFF_MIN_ORDER=1

# Учитывать текст сообщения, на которое отвечают, как контекст для генерации
USE_REPLY_CONTEXT=true

# Максимум токенов, которые берутся из reply-контекста
REPLY_CONTEXT_MAX_TOKENS=12

# Сколько последних токенов контекста использовать как приоритетный старт (2 или 3)
REPLY_CONTEXT_LAST_TOKENS=3

# Насколько усиливать выбор токенов, связанных с reply-контекстом
REPLY_CONTEXT_BIAS=1.8

# Насколько усиливать выбор стартовой цепочки, найденной в reply-контексте
REPLY_CONTEXT_START_BIAS=2.2

# Применять контекст только для Telegram reply-сообщений
REPLY_CONTEXT_ONLY_FOR_REPLIES=true

# Добавлять токены текущего сообщения к reply-контексту
REPLY_CONTEXT_INCLUDE_CURRENT_MESSAGE=true
